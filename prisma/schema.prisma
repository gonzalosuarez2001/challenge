generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Counter {
  id            Int      @id @default(autoincrement())
  value         Int      @default(0)
  lastUpdatedAt DateTime @default(now()) @updatedAt @map("last_updated_at")

  @@map("counters")
}
